---
interface Props {
  variant?: 'line' | 'ornament' | 'dots' | 'floral';
}

const { variant = 'line' } = Astro.props;
---

<div class="flex items-center justify-center py-4" aria-hidden="true">
  {variant === 'line' && (
    <div class="h-px w-32 bg-gradient-to-r from-transparent via-gold/30 to-transparent" />
  )}
  {variant === 'ornament' && (
    <div class="flex items-center gap-4">
      <div class="h-px w-16 bg-gradient-to-r from-transparent to-gold/30" />
      <div class="h-1.5 w-1.5 rotate-45 bg-gold/40" />
      <div class="h-px w-16 bg-gradient-to-l from-transparent to-gold/30" />
    </div>
  )}
  {variant === 'dots' && (
    <div class="flex items-center gap-3">
      <div class="h-1 w-1 rounded-full bg-gold/25" />
      <div class="h-1.5 w-1.5 rounded-full bg-gold/40" />
      <div class="h-1 w-1 rounded-full bg-gold/25" />
    </div>
  )}
  {variant === 'floral' && (
    <div class="floral-divider flex items-center gap-6 py-4">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-gold/20" />
      <svg viewBox="0 0 60 40" fill="none" class="h-8 w-12 text-gold/30" xmlns="http://www.w3.org/2000/svg">
        <!-- Left leaf -->
        <path d="M30 20 C20 12, 8 14, 6 20 C4 26, 14 30, 30 20Z" stroke="currentColor" stroke-width="0.8" fill="none" />
        <path d="M30 20 C18 16, 10 18, 6 20" stroke="currentColor" stroke-width="0.4" />
        <!-- Right leaf -->
        <path d="M30 20 C40 12, 52 14, 54 20 C56 26, 46 30, 30 20Z" stroke="currentColor" stroke-width="0.8" fill="none" />
        <path d="M30 20 C42 16, 50 18, 54 20" stroke="currentColor" stroke-width="0.4" />
        <!-- Small top bud -->
        <path d="M30 8 C26 10, 26 16, 30 18 C34 16, 34 10, 30 8Z" stroke="currentColor" stroke-width="0.6" fill="none" />
        <!-- Stem -->
        <path d="M30 18 L30 34" stroke="currentColor" stroke-width="0.6" />
        <!-- Small bottom leaves -->
        <path d="M30 28 C24 26, 22 28, 24 30 C26 32, 28 30, 30 28Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M30 28 C36 26, 38 28, 36 30 C34 32, 32 30, 30 28Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-gold/20" />
    </div>
  )}
</div>
